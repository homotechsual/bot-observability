# Copy this file to .env and customize values.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Use absolute paths on the machine where docker compose runs.
# HaloCommunityBot Serilog folder usually ends with /src/HaloCommunityBot/bin/Debug/net10.0/logs
HALO_LOG_PATH=C:/path/to/HaloCommunityBot/logs

# PandaBot Serilog folder usually ends with /src/PandaBot/bin/Debug/net10.0/logs
PANDA_LOG_PATH=C:/path/to/PandaBot/logs

# HuduCommunityBot Serilog folder usually ends with /src/HuduCommunityBot/bin/Debug/net10.0/logs
HUDU_LOG_PATH=C:/path/to/HuduCommunityBot/logs

# Uptime Kuma Prometheus API key for /metrics scraping when auth is enabled.
# Also write this value to ./secrets/kuma_metrics_api_key for local runs.
KUMA_METRICS_API_KEY=

# Raw feed exporter source URLs (used for Last Source Feed Activity panels).
# YouTube Atom RSS feed URLs separated by commas, e.g.:
# https://www.youtube.com/feeds/videos.xml?channel_id=UCxxxxxx
# Optional manual fallback URLs can be listed in YOUTUBE_FEED_URLS.
# Preferred source is each bot endpoint below (derived from bot DB state).
YOUTUBE_FEED_URLS=
HALO_YOUTUBE_FEED_URLS_ENDPOINT=http://host.docker.internal:9191/observability/youtube-feed-urls
HUDU_YOUTUBE_FEED_URLS_ENDPOINT=http://host.docker.internal:9192/observability/youtube-feed-urls
HALO_STATUS_FEED_URL=https://status.haloservicesolutions.com/pages/63ef45da7ee94905308a1a4a/rss
HUDU_RELEASE_FEED_URL=https://hq.hudu.com/public/releases.json
